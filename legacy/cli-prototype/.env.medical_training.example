# Medical Training System Environment Configuration
# Copy this file to .env and update the values according to your setup

# =============================================================================
# Laravel Application Settings
# =============================================================================
APP_NAME="Medical Training System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# =============================================================================
# Database Configuration
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=medical_training
DB_USERNAME=root
DB_PASSWORD=

# =============================================================================
# Medical Training AI Configuration
# =============================================================================
# OpenRouter API settings for AI integration
MEDICAL_AI_API_URL=https://openrouter.ai/api/v1/chat/completions
MEDICAL_AI_API_KEY=your_openrouter_api_key_here
MEDICAL_AI_MODEL=anthropic/claude-3.5-sonnet
MEDICAL_AI_MAX_RETRIES=3
MEDICAL_AI_TIMEOUT=30
MEDICAL_AI_MAX_TOKENS=4000
MEDICAL_AI_TEMPERATURE=0.7

# Alternative AI Providers (uncomment and configure as needed)
# MEDICAL_AI_API_URL=https://api.openai.com/v1/chat/completions
# MEDICAL_AI_MODEL=gpt-4
# MEDICAL_AI_API_URL=https://api.anthropic.com/v1/messages
# MEDICAL_AI_MODEL=claude-3-sonnet-20240229

# =============================================================================
# Chat System Configuration
# =============================================================================
MEDICAL_CHAT_MAX_HISTORY=10
MEDICAL_CHAT_SUMMARIZE_THRESHOLD=6
MEDICAL_CHAT_AUTO_SUMMARIZE=true
MEDICAL_CHAT_MAX_MESSAGE_LENGTH=2000

# =============================================================================
# OSCE System Configuration
# =============================================================================
MEDICAL_OSCE_DEFAULT_DURATION=1200
MEDICAL_OSCE_MAX_DURATION=3600
MEDICAL_OSCE_AUTO_COMPLETE_THRESHOLD=90
MEDICAL_OSCE_PASSING_SCORE=60
MEDICAL_OSCE_EXCELLENT_SCORE=85
MEDICAL_OSCE_AUTO_DETECTION=true
MEDICAL_OSCE_KEYWORD_MATCHING=true
MEDICAL_OSCE_CASE_SENSITIVE=false
MEDICAL_OSCE_RESPONSE_DELAY=500
MEDICAL_OSCE_PERSONALITY_CONSISTENCY=true
MEDICAL_OSCE_EMOTION_SIMULATION=true

# =============================================================================
# Session Management
# =============================================================================
MEDICAL_SESSION_DURATION=7200
MEDICAL_SESSION_CLEANUP_DAYS=30
MEDICAL_SESSION_ENABLE_STATS=true
MEDICAL_SESSION_TRACK_PERFORMANCE=true
MEDICAL_SESSION_AUTO_END=true
MEDICAL_SESSION_INACTIVE_TIMEOUT=1800

# =============================================================================
# Health Monitoring
# =============================================================================
MEDICAL_HEALTH_MONITORING=true
MEDICAL_HEALTH_CHECK_INTERVAL=300
MEDICAL_HEALTH_API_TIMEOUT=5000
MEDICAL_HEALTH_ERROR_RATE=10
MEDICAL_HEALTH_RESPONSE_TIME=3000
MEDICAL_HEALTH_AUTO_RECOVERY=false
MEDICAL_HEALTH_LOG_RETENTION=7

# =============================================================================
# Security Settings
# =============================================================================
MEDICAL_RATE_LIMIT_CHAT=60
MEDICAL_RATE_LIMIT_OSCE=30
MEDICAL_RATE_LIMIT_API=100
MEDICAL_SECURITY_LOG_REQUESTS=true
MEDICAL_SECURITY_LOG_SENSITIVE=false
MEDICAL_SECURITY_IP_FILTERING=false
MEDICAL_SECURITY_ALLOWED_IPS=

# =============================================================================
# Feature Flags
# =============================================================================
MEDICAL_FEATURE_CHAT=true
MEDICAL_FEATURE_OSCE=true
MEDICAL_FEATURE_ANALYTICS=true
MEDICAL_FEATURE_EXPORT=true
MEDICAL_FEATURE_FEEDBACK=true
MEDICAL_FEATURE_TUTORIALS=true
MEDICAL_FEATURE_ADVANCED_SCORING=false
MEDICAL_FEATURE_AI_FEEDBACK=true

# =============================================================================
# Localization
# =============================================================================
MEDICAL_DEFAULT_LANGUAGE=id
MEDICAL_AUTO_TRANSLATION=false
MEDICAL_PATIENT_LANGUAGE=id

# =============================================================================
# Performance Settings
# =============================================================================
MEDICAL_ENABLE_CACHING=true
MEDICAL_CACHE_TTL=3600
MEDICAL_ENABLE_COMPRESSION=true
MEDICAL_MAX_CONCURRENT_SESSIONS=100
MEDICAL_ENABLE_RESPONSE_CACHING=false
MEDICAL_DB_QUERY_TIMEOUT=30

# =============================================================================
# Development & Testing
# =============================================================================
MEDICAL_DEBUG_MODE=false
MEDICAL_MOCK_AI=false
MEDICAL_ENABLE_TEST_CASES=false
MEDICAL_LOG_LEVEL=info
MEDICAL_ENABLE_PROFILING=false

# =============================================================================
# Laravel Standard Configuration
# =============================================================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"