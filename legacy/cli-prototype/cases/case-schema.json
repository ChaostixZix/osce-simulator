{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "OSCE Medical Case Schema",
  "description": "Schema for validating OSCE medical case JSON files",
  "required": [
    "id",
    "title",
    "description",
    "chiefComplaint",
    "patientInfo",
    "presentingSymptoms",
    "medicalHistory",
    "physicalExamination",
    "investigations",
    "checklist",
    "expectedDiagnosis",
    "learningObjectives"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for the case"
    },
    "title": {
      "type": "string",
      "description": "Case title"
    },
    "description": {
      "type": "string",
      "description": "Brief case description"
    },
    "chiefComplaint": {
      "type": "string",
      "description": "Patient's chief complaint"
    },
    "patientInfo": {
      "type": "object",
      "required": ["age", "gender", "name"],
      "properties": {
        "age": {
          "type": "integer",
          "minimum": 0,
          "maximum": 120
        },
        "gender": {
          "type": "string",
          "enum": ["male", "female", "other"]
        },
        "name": {
          "type": "string"
        },
        "occupation": {
          "type": "string"
        }
      }
    },
    "presentingSymptoms": {
      "type": "object",
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string"
        },
        "associated": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "onset": {
          "type": "string"
        },
        "character": {
          "type": "string"
        },
        "radiation": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        }
      }
    },
    "medicalHistory": {
      "type": "object",
      "required": ["pastMedical", "medications", "allergies"],
      "properties": {
        "pastMedical": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "medications": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "allergies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "socialHistory": {
          "type": "object",
          "properties": {
            "smoking": {
              "type": "string"
            },
            "alcohol": {
              "type": "string"
            },
            "familyHistory": {
              "type": "string"
            }
          }
        }
      }
    },
    "physicalExamination": {
      "type": "object",
      "required": ["vitalSigns"],
      "properties": {
        "vitalSigns": {
          "type": "object",
          "required": ["bp", "hr", "rr", "temp"],
          "properties": {
            "bp": {
              "type": "string"
            },
            "hr": {
              "type": "string"
            },
            "rr": {
              "type": "string"
            },
            "temp": {
              "type": "string"
            },
            "o2sat": {
              "type": "string"
            }
          }
        },
        "general": {
          "type": "string"
        },
        "cardiovascular": {
          "type": "string"
        },
        "respiratory": {
          "type": "string"
        },
        "other": {
          "type": "string"
        }
      }
    },
    "investigations": {
      "type": "object",
      "properties": {
        "ecg": {
          "type": "object",
          "properties": {
            "findings": {
              "type": "string"
            },
            "interpretation": {
              "type": "string"
            }
          }
        },
        "labs": {
          "type": "object"
        },
        "imaging": {
          "type": "object"
        }
      }
    },
    "checklist": {
      "type": "object",
      "patternProperties": {
        "^[a-zA-Z]+$": {
          "type": "object",
          "required": ["weight", "items"],
          "properties": {
            "weight": {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "description", "critical", "points"],
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "critical": {
                    "type": "boolean"
                  },
                  "points": {
                    "type": "integer",
                    "minimum": 0
                  }
                }
              }
            }
          }
        }
      }
    },
    "expectedDiagnosis": {
      "type": "string"
    },
    "learningObjectives": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}