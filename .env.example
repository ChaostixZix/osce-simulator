APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Optional: if using a different Redis for cache/session
# REDIS_DB=0
# REDIS_CACHE_DB=1

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_REDIRECT_URL="http://localhost:8000/authenticate"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Vite dev server configuration
# Use your machine's accessible host/IP when browsing from another device.
# Example for LAN: APP_URL=http://192.168.1.10:8000
# Example for LAN: VITE_DEV_SERVER_URL=http://192.168.1.10:5173
VITE_DEV_SERVER_URL=
# Hostname/IP used by Vite HMR websocket (set to your IP when not using localhost)
VITE_HMR_HOST=
# Public port used by Vite HMR websocket (defaults to 5173)
VITE_HMR_CLIENT_PORT=5173
# Optional: override Vite dev port (must match package.json and vite.config.ts)
VITE_DEV_PORT=5173

# AI Patient Service Configuration
# Set AI_PROVIDER to either "gemini" or "openai" to choose the AI service
AI_PROVIDER=gemini

# Gemini Configuration
# Note: config/services.php and config/gemini.php have different defaults.
# Set GEMINI_MODEL explicitly to avoid mismatch.
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT=30                 # seconds (optional)
GEMINI_RATE_LIMIT=60              # requests/minute (optional)
GEMINI_MAX_CONCURRENT=5           # in-flight requests (optional)
GEMINI_FALLBACK_ENABLED=true      # allow degraded results (optional)

# OpenAI Azure Configuration
OPENAI_AZURE_API_KEY=
OPENAI_AZURE_ENDPOINT=
OPENAI_AZURE_DEPLOYMENT=
OPENAI_AZURE_TIMEOUT=30           # seconds (optional)

# Multi-Prompt Assessment Configuration
USE_MULTI_PROMPT_ASSESSMENT=true   # Enable/disable multi-prompt assessment system
